# Supply chain attack mitigation: enforce package release age cooldown.
# Newly published versions cannot be installed until they have aged enough,
# avoiding the typical window of npm-style worm/credential-stealer attacks.

# pnpm (>=9): minutes. 10080 = 7 days
minimum-release-age=10080
minimum-release-age-exclude=typescript,@types/*

# npm (>=11.10): days
min-release-age=7
