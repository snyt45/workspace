#!/bin/bash
# tmux-partial-zoom: 縦方向のみペインを最大化するトグル
# 通常のzoom (resize-pane -Z) と違い、横のレイアウトはそのまま。
# ai-dualレイアウトで右カラムの片方だけ最大化したい時に使う。
#
# 復元の堅さのため window_layout を保存 → select-layout で丸ごと戻す。

pane_id=$(tmux display-message -p '#{pane_id}')
key="${pane_id//%/}"
layout_var="PZOOM_LAYOUT_${key}"

raw=$(tmux show-environment -g "$layout_var" 2>/dev/null)
# 未設定時は空 or "-VAR" (削除マーカー) が返るので '=' を含む行だけ採用する
if [[ "$raw" == *=* ]]; then
  saved_layout="${raw#*=}"
else
  saved_layout=""
fi

if [[ -n "$saved_layout" ]]; then
  tmux select-layout "$saved_layout"
  tmux set-environment -gu "$layout_var"
else
  current_layout=$(tmux display-message -p '#{window_layout}')
  tmux set-environment -g "$layout_var" "$current_layout"
  tmux resize-pane -y 1000
fi
