#!/bin/bash

show_preview() {
  case "$1" in
    ai-single*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ c / cx  │
│      editor       │         │
│                   │         │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%

EOF
      ;;
    ai-dual*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │ c / cx  │
│                   │ (上段)  │
│      editor       ├─────────┤
│                   │ c / cx  │
│                   │ (下段)  │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%
  上下それぞれ c / cx を選択

EOF
      ;;
    dev-full*)
      cat <<'EOF'
┌─────────────────────────────┐
│           editor            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
├─────────┼─────────┼─────────┤
│ term 4  │ term 5  │ term 6  │
└─────────┴─────────┴─────────┘

EOF
      ;;
    dev*)
      cat <<'EOF'
┌─────────────────────────────┐
│           editor            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
└─────────┴─────────┴─────────┘

EOF
      ;;
    pair*)
      cat <<'EOF'
┌──────────────┬──────────────┐
│              │              │
│   editor 1   │   editor 2   │
│              │              │
├──────────────┴──────────────┤
│           terminal          │
└─────────────────────────────┘
  左50%            右50%

EOF
      ;;
  esac
}

select_agent() {
  local agents="c	opencode
cx	claude --enable-auto-mode"

  local selected
  selected=$(echo "$agents" | fzf \
    --height=20% \
    --layout=reverse \
    --delimiter=$'\t' \
    --with-nth=1.. \
    --header="エージェントを選択" \
    --no-info)

  if [[ -z "$selected" ]]; then
    return 1
  fi

  echo "$selected" | cut -f1
}

apply_layout() {
  case "$1" in
    dev)
      # 下段（25%）を作成
      tmux split-window -v -l 25%
      # 下段を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # エディタにフォーカス
      tmux select-pane -t 0
      ;;
    dev-full)
      # 3行目（下25%）を作成
      tmux split-window -v -l 25%
      # 3行目を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # 1行目に戻って2行目（残りの下33%）を作成
      tmux select-pane -t 0
      tmux split-window -v -l 33%
      # 2行目を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # エディタにフォーカス
      tmux select-pane -t 0
      ;;
    ai-dual)
      local top_agent="$2"
      local bottom_agent="$3"
      if [[ -z "$top_agent" ]]; then
        echo "上段エージェント:"
        top_agent=$(select_agent)
        [[ -z "$top_agent" ]] && return 0
      fi
      if [[ -z "$bottom_agent" ]]; then
        echo "下段エージェント:"
        bottom_agent=$(select_agent)
        [[ -z "$bottom_agent" ]] && return 0
      fi
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインの右30%を分割してAIペインを作成
      local ai_pane
      ai_pane=$(tmux split-window -h -l 30% -t "$editor_pane" -P -F '#{pane_id}')
      # AIペインを縦分割して下段AIペインを作成
      local bottom_pane
      bottom_pane=$(tmux split-window -v -t "$ai_pane" -P -F '#{pane_id}')
      # 各ペインでコマンドを起動
      tmux send-keys -t "$ai_pane" "$top_agent" C-m
      tmux send-keys -t "$bottom_pane" "$bottom_agent" C-m
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      # エディタにフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
    ai-single)
      local agent="$2"
      if [[ -z "$agent" ]]; then
        agent=$(select_agent)
        [[ -z "$agent" ]] && return 0
      fi
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインの右30%を分割してAIペインを作成
      local ai_pane
      ai_pane=$(tmux split-window -h -l 30% -t "$editor_pane" -P -F '#{pane_id}')
      # AIペインでエージェントを起動
      tmux send-keys -t "$ai_pane" "$agent" C-m
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      # エディタにフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
    pair)
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインを左右50%で分割
      local right_pane
      right_pane=$(tmux split-window -h -l 50% -t "$editor_pane" -P -F '#{pane_id}')
      # 両方でエディタを起動
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      tmux send-keys -t "$right_pane" "$EDITOR ." C-m
      # 左にフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
  esac

  # Starshipのプロンプト初期化を待ってからクリア
  sleep 0.2
  pane_count=$(tmux list-panes | wc -l)
  for i in $(seq 0 $((pane_count - 1))); do
    tmux select-pane -t "$i" 2>/dev/null && tmux send-keys C-l
  done
  tmux select-pane -t 0
}

# --preview モードの場合（fzfから呼ばれる）
if [[ "$1" == "--preview" ]]; then
  show_preview "$2"
  exit 0
fi

# 引数があればそのまま実行
if [[ -n "$1" ]]; then
  case "$1" in
    dev|dev-full|pair)
      apply_layout "$1"
      exit 0
      ;;
    ai-single)
      apply_layout "$1" "$2"
      exit 0
      ;;
    ai-dual)
      apply_layout "$1" "$2" "$3"
      exit 0
      ;;
    *)
      echo "Unknown layout: $1"
      exit 1
      ;;
  esac
fi

# fzfで選択
layouts="ai-single
ai-dual
dev
dev-full
pair"

selected=$(echo "$layouts" | fzf \
  --height=40% \
  --layout=reverse \
  --delimiter=$'\t' \
  --with-nth=1.. \
  --preview="$0 --preview {1}" \
  --preview-window=right:40% \
  --header="レイアウトを選択" \
  --no-info)

if [[ -z "$selected" ]]; then
  exit 0
fi

layout=$(echo "$selected" | cut -f1)
apply_layout "$layout"
