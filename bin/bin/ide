#!/bin/bash

show_preview() {
  case "$1" in
    default*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ term 1  │
│      term 0       │         │
│                   │         │
├───────────────────┴─────────┤
│           term 2            │
└─────────────────────────────┘
  左70%              右30%

EOF
      ;;
    ai-single*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ c / cx  │
│      editor       │         │
│                   │         │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%

EOF
      ;;
    ai-dual*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │ c / cx  │
│                   │ (上段)  │
│      editor       ├─────────┤
│                   │ c / cx  │
│                   │ (下段)  │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%
  上下それぞれ c / cx を選択

EOF
      ;;
    pair-ai*)
      cat <<'EOF'
┌───────────┬───────────┬─────┐
│           │           │     │
│ editor 1  │ editor 2  │c/cx │
│           │           │     │
├───────────┴───────────┴─────┤
│          terminal           │
└─────────────────────────────┘
  左40%      中40%    右20%

EOF
      ;;
    pair*)
      cat <<'EOF'
┌──────────────┬──────────────┐
│              │              │
│   editor 1   │   editor 2   │
│              │              │
├──────────────┴──────────────┤
│           terminal          │
└─────────────────────────────┘
  左50%            右50%

EOF
      ;;
    grid-full*)
      cat <<'EOF'
┌─────────────────────────────┐
│           term 0            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
├─────────┼─────────┼─────────┤
│ term 4  │ term 5  │ term 6  │
└─────────┴─────────┴─────────┘

EOF
      ;;
    grid*)
      cat <<'EOF'
┌─────────────────────────────┐
│           term 0            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
└─────────┴─────────┴─────────┘

EOF
      ;;
  esac
}

select_agent() {
  local agents="c	opencode
cx	claude --enable-auto-mode"

  local selected
  selected=$(echo "$agents" | fzf \
    --height=20% \
    --layout=reverse \
    --delimiter=$'\t' \
    --with-nth=1.. \
    --header="エージェントを選択" \
    --no-info)

  if [[ -z "$selected" ]]; then
    return 1
  fi

  echo "$selected" | cut -f1
}

apply_layout() {
  case "$1" in
    default)
      local base_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # 上段の右30%を分割
      tmux split-window -h -l 30% -t "$base_pane"
      # 左上にフォーカス
      tmux select-pane -t "$base_pane"
      ;;
    grid)
      local top_pane="$TMUX_PANE"
      # 下段（25%）を作成
      tmux split-window -v -l 25%
      # 下段を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # 上段にフォーカス
      tmux select-pane -t "$top_pane"
      ;;
    grid-full)
      local top_pane="$TMUX_PANE"
      # 3行目（下25%）を作成
      tmux split-window -v -l 25%
      # 3行目を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # 1行目に戻って2行目（残りの下33%）を作成
      tmux select-pane -t "$top_pane"
      tmux split-window -v -l 33%
      # 2行目を3分割
      tmux split-window -h -l 66%
      tmux split-window -h -l 50%
      # 上段にフォーカス
      tmux select-pane -t "$top_pane"
      ;;
    ai-dual)
      local top_agent="$2"
      local bottom_agent="$3"
      if [[ -z "$top_agent" ]]; then
        echo "上段エージェント:"
        top_agent=$(select_agent)
        [[ -z "$top_agent" ]] && return 0
      fi
      if [[ -z "$bottom_agent" ]]; then
        echo "下段エージェント:"
        bottom_agent=$(select_agent)
        [[ -z "$bottom_agent" ]] && return 0
      fi
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインの右30%を分割してAIペインを作成
      local ai_pane
      ai_pane=$(tmux split-window -h -l 30% -t "$editor_pane" -P -F '#{pane_id}')
      # AIペインを縦分割して下段AIペインを作成
      local bottom_pane
      bottom_pane=$(tmux split-window -v -t "$ai_pane" -P -F '#{pane_id}')
      # 各ペインでコマンドを起動
      tmux send-keys -t "$ai_pane" "$top_agent" C-m
      tmux send-keys -t "$bottom_pane" "$bottom_agent" C-m
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      # エディタにフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
    ai-single)
      local agent="$2"
      if [[ -z "$agent" ]]; then
        agent=$(select_agent)
        [[ -z "$agent" ]] && return 0
      fi
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインの右30%を分割してAIペインを作成
      local ai_pane
      ai_pane=$(tmux split-window -h -l 30% -t "$editor_pane" -P -F '#{pane_id}')
      # AIペインでエージェントを起動
      tmux send-keys -t "$ai_pane" "$agent" C-m
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      # エディタにフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
    pair)
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインを左右50%で分割
      local right_pane
      right_pane=$(tmux split-window -h -l 50% -t "$editor_pane" -P -F '#{pane_id}')
      # 両方でエディタを起動
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      tmux send-keys -t "$right_pane" "$EDITOR ." C-m
      # 左にフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
    pair-ai)
      local agent="$2"
      if [[ -z "$agent" ]]; then
        agent=$(select_agent)
        [[ -z "$agent" ]] && return 0
      fi
      local editor_pane="$TMUX_PANE"
      # 下段（15%）を作成
      tmux split-window -v -l 15%
      # エディタペインの右20%を分割してAIペインを作成
      local ai_pane
      ai_pane=$(tmux split-window -h -l 20% -t "$editor_pane" -P -F '#{pane_id}')
      # 残った左側(80%)を左右50%で分割して editor2 を作成
      local editor2_pane
      editor2_pane=$(tmux split-window -h -l 50% -t "$editor_pane" -P -F '#{pane_id}')
      # 各ペインでコマンドを起動
      tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
      tmux send-keys -t "$editor2_pane" "$EDITOR ." C-m
      tmux send-keys -t "$ai_pane" "$agent" C-m
      # 左のエディタにフォーカス
      tmux select-pane -t "$editor_pane"
      ;;
  esac

  # 各ペインで画面クリア
  local final_pane=$(tmux display-message -p '#{pane_id}')
  for pane in $(tmux list-panes -F '#{pane_id}'); do
    tmux select-pane -t "$pane" && tmux send-keys C-l
  done
  tmux select-pane -t "$final_pane"
}

# --preview モードの場合（fzfから呼ばれる）
if [[ "$1" == "--preview" ]]; then
  show_preview "$2"
  exit 0
fi

# 引数があればそのまま実行
if [[ -n "$1" ]]; then
  case "$1" in
    default|grid|grid-full|pair)
      apply_layout "$1"
      exit 0
      ;;
    ai-single)
      apply_layout "$1" "$2"
      exit 0
      ;;
    ai-dual)
      apply_layout "$1" "$2" "$3"
      exit 0
      ;;
    pair-ai)
      apply_layout "$1" "$2"
      exit 0
      ;;
    *)
      echo "Unknown layout: $1"
      exit 1
      ;;
  esac
fi

# fzfで選択
layouts="default
ai-single
ai-dual
pair
pair-ai
grid
grid-full"

selected=$(echo "$layouts" | fzf \
  --height=40% \
  --layout=reverse \
  --delimiter=$'\t' \
  --with-nth=1.. \
  --preview="$0 --preview {1}" \
  --preview-window=right:40% \
  --header="レイアウトを選択" \
  --no-info)

if [[ -z "$selected" ]]; then
  exit 0
fi

layout=$(echo "$selected" | cut -f1)
apply_layout "$layout"
