#!/usr/bin/env zsh
# herdr内でIDEレイアウトを組む (bin/ide のherdr版)
# 使い方: herdrのペインでプロジェクトディレクトリに移動して herdr-ide [レイアウト] [エージェント...]
# 引数なしはfzfで選択（プレビュー付き）
# 分割ペインのcwdは実行ペインを引き継ぐ(new_cwd=follow)
# 注: herdrのsplit --ratio は「元ペインが保持する割合」(tmuxの -l は新ペインの割合)

show_preview() {
  case "$1" in
    default-quad*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ term 1  │
│      term 0       │         │
│                   │         │
├───────┬──────┬────┴─┬───────┤
│term 2 │term 3│term 4│term 5 │
└───────┴──────┴──────┴───────┘
  左70%              右30%
  下段は25%ずつ4分割

EOF
      ;;
    default*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ term 1  │
│      term 0       │         │
│                   │         │
├───────────────────┴─────────┤
│           term 2            │
└─────────────────────────────┘
  左70%              右30%

EOF
      ;;
    ai-single*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │         │
│                   │ c / cx  │
│       term        │         │
│                   │         │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%

EOF
      ;;
    ai-dual*)
      cat <<'EOF'
┌───────────────────┬─────────┐
│                   │ c / cx  │
│                   │ (上段)  │
│       term        ├─────────┤
│                   │ c / cx  │
│                   │ (下段)  │
├───────────────────┴─────────┤
│           terminal          │
└─────────────────────────────┘
  左70%              右30%
  上下それぞれ c / cx を選択

EOF
      ;;
    pair-ai*)
      cat <<'EOF'
┌───────────┬───────────┬─────┐
│           │           │     │
│ term 1    │ term 2    │c/cx │
│           │           │     │
├───────────┴───────────┴─────┤
│          terminal           │
└─────────────────────────────┘
  左40%      中40%    右20%

EOF
      ;;
    pair*)
      cat <<'EOF'
┌──────────────┬──────────────┐
│              │              │
│    term 1    │    term 2    │
│              │              │
├──────────────┴──────────────┤
│           terminal          │
└─────────────────────────────┘
  左50%            右50%

EOF
      ;;
    grid-full*)
      cat <<'EOF'
┌─────────────────────────────┐
│           term 0            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
├─────────┼─────────┼─────────┤
│ term 4  │ term 5  │ term 6  │
└─────────┴─────────┴─────────┘

EOF
      ;;
    grid*)
      cat <<'EOF'
┌─────────────────────────────┐
│           term 0            │
├─────────┬─────────┬─────────┤
│ term 1  │ term 2  │ term 3  │
└─────────┴─────────┴─────────┘

EOF
      ;;
  esac
}

# --preview モードの場合（fzfから呼ばれる）
if [[ "$1" == "--preview" ]]; then
  show_preview "$2"
  exit 0
fi

if [[ -z "$HERDR_PANE_ID" ]]; then
  echo "herdrのペイン内で実行してください" >&2
  exit 1
fi

select_agent() {
  local agents="c	opencode
cx	claude --enable-auto-mode
pi	pi"

  local selected
  selected=$(echo "$agents" | fzf \
    --height=20% \
    --layout=reverse \
    --delimiter=$'\t' \
    --with-nth=1.. \
    --header="エージェントを選択" \
    --no-info)

  if [[ -z "$selected" ]]; then
    return 1
  fi

  echo "$selected" | cut -f1
}

pane_id() { grep -o '"pane_id":"[^"]*"' | head -1 | cut -d'"' -f4 }
sp() { herdr pane split "$1" --direction "$2" --ratio "$3" --no-focus | pane_id }
run_in() { herdr pane run "$1" "$2" >/dev/null }

apply_layout() {
  local p1=$HERDR_PANE_ID
  case "$1" in
    default)
      # 下段(15%)と右30%を作成
      sp $p1 down 0.85 >/dev/null
      sp $p1 right 0.70 >/dev/null
      ;;
    default-quad)
      # 下段(15%)を作成して25%ずつ4分割、右30%も作成
      local bottom=$(sp $p1 down 0.85)
      sp $p1 right 0.70 >/dev/null
      local b2=$(sp $bottom right 0.25)
      local b3=$(sp $b2 right 0.34)
      sp $b3 right 0.5 >/dev/null
      ;;
    ai-single)
      local agent="$2"
      if [[ -z "$agent" ]]; then
        agent=$(select_agent)
        [[ -z "$agent" ]] && return 0
      fi
      sp $p1 down 0.85 >/dev/null
      local ai_pane=$(sp $p1 right 0.70)
      sleep 1
      run_in $ai_pane "$agent"
      ;;
    ai-dual)
      local top_agent="$2"
      local bottom_agent="$3"
      if [[ -z "$top_agent" ]]; then
        echo "上段エージェント:"
        top_agent=$(select_agent)
        [[ -z "$top_agent" ]] && return 0
      fi
      if [[ -z "$bottom_agent" ]]; then
        echo "下段エージェント:"
        bottom_agent=$(select_agent)
        [[ -z "$bottom_agent" ]] && return 0
      fi
      sp $p1 down 0.85 >/dev/null
      local ai_pane=$(sp $p1 right 0.70)
      local bottom_pane=$(sp $ai_pane down 0.5)
      sleep 1
      run_in $ai_pane "$top_agent"
      run_in $bottom_pane "$bottom_agent"
      ;;
    pair)
      sp $p1 down 0.85 >/dev/null
      sp $p1 right 0.50 >/dev/null
      ;;
    pair-ai)
      local agent="$2"
      if [[ -z "$agent" ]]; then
        agent=$(select_agent)
        [[ -z "$agent" ]] && return 0
      fi
      sp $p1 down 0.85 >/dev/null
      local ai_pane=$(sp $p1 right 0.80)
      sp $p1 right 0.50 >/dev/null
      sleep 1
      run_in $ai_pane "$agent"
      ;;
    grid)
      local bottom=$(sp $p1 down 0.75)
      local b2=$(sp $bottom right 0.34)
      sp $b2 right 0.5 >/dev/null
      ;;
    grid-full)
      local row3=$(sp $p1 down 0.75)
      local r3b=$(sp $row3 right 0.34)
      sp $r3b right 0.5 >/dev/null
      local row2=$(sp $p1 down 0.67)
      local r2b=$(sp $row2 right 0.34)
      sp $r2b right 0.5 >/dev/null
      ;;
  esac
}

# 引数があればそのまま実行
if [[ -n "$1" ]]; then
  case "$1" in
    default|default-quad|grid|grid-full|pair)
      apply_layout "$1"
      exit 0
      ;;
    ai-single|pair-ai)
      apply_layout "$1" "$2"
      exit 0
      ;;
    ai-dual)
      apply_layout "$1" "$2" "$3"
      exit 0
      ;;
    *)
      echo "Unknown layout: $1"
      exit 1
      ;;
  esac
fi

# fzfで選択
layouts="default
default-quad
ai-single
ai-dual
pair
pair-ai
grid
grid-full"

selected=$(echo "$layouts" | fzf \
  --height=40% \
  --layout=reverse \
  --delimiter=$'\t' \
  --with-nth=1.. \
  --preview="$0 --preview {1}" \
  --preview-window=right:40% \
  --header="レイアウトを選択" \
  --no-info)

if [[ -z "$selected" ]]; then
  exit 0
fi

layout=$(echo "$selected" | cut -f1)
apply_layout "$layout"
