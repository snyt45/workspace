{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "Created by author with Claude Code",
    "pr": "このPRはClaude Codeを活用して作成しました"
  },
  "permissions": {
    "allow": [
      "Glob",
      "Read",
      "Edit(./**/*)",
      "Write",
      "Grep",
      "WebSearch",
      "WebFetch",
      "TodoWrite",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(sort:*)",
      "Bash(tr:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git clone:*)",
      "Bash(git restore --staged:*)",
      "Bash(git grep:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh search code:*)",
      "Bash(gh search issues:*)",
      "Bash(gh search prs:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm ls:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(make:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(mise ls:*)",
      "Bash(mise current:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*secret*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(dd:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)"
    ],
    "additionalDirectories": [
      "~/.claude",
      "~/work"
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "superpowers@superpowers-marketplace": true,
    "ruby-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "language": "ja",
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754364589827
  }
}
